{
  "name": "shanks",
  "productName": "Shanks",
  "version": "0.2.0",
  "description": "컴퓨터 안에서 함께 일하는 동반자 콤냥이 — 뽀모도로 + 건강 케어 데스크탑 펫",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "electron:dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.shanks.app",
    "productName": "Shanks",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/shanks-logo.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/shanks-logo.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/shanks-logo.png"
    }
  }
}
